{
  "name": "pulse-mobile",
  "version": "1.0.0",
  "description": "React Native iOS/Android music player with offline downloads, YouTube Music API, and podcast support. Requires Expo SDK 52 + React Native 0.76.5.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "type-check": "tsc --noEmit",
    "start:clear": "expo start --clear",
    "lint": "echo 'No linter configured'",
    "build:ios": "eas build --platform ios --profile preview",
    "build:ios:prod": "eas build --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/netinfo": "^11.0.0",
    "@react-native-community/slider": "^4.5.3",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "expo": "~52.0.0",
    "expo-av": "~14.0.7",
    "expo-blur": "~14.0.1",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~13.0.1",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "^56.0.14",
    "expo-media-library": "~16.0.4",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "^56.0.5",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.1",
    "typescript": "^5.3.3"
  }
}
